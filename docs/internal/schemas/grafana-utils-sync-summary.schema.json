{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grafana-utils.local/docs/internal/schemas/grafana-utils-sync-summary.schema.json",
  "title": "grafana-utils-sync-summary",
  "type": "object",
  "required": [
    "kind",
    "schemaVersion",
    "summary",
    "resources"
  ],
  "properties": {
    "kind": {
      "const": "grafana-utils-sync-summary"
    },
    "schemaVersion": {
      "const": 1
    },
    "summary": {
      "type": "object",
      "required": [
        "resourceCount",
        "dashboardCount",
        "datasourceCount",
        "folderCount",
        "alertCount"
      ],
      "properties": {
        "resourceCount": {
          "type": "integer",
          "minimum": 0
        },
        "dashboardCount": {
          "type": "integer",
          "minimum": 0
        },
        "datasourceCount": {
          "type": "integer",
          "minimum": 0
        },
        "folderCount": {
          "type": "integer",
          "minimum": 0
        },
        "alertCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "identity",
          "managedFields",
          "sourcePath",
          "bodyFieldCount"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "dashboard",
              "datasource",
              "folder",
              "alert"
            ]
          },
          "identity": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "managedFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sourcePath": {
            "type": "string"
          },
          "bodyFieldCount": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
