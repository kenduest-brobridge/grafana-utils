{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grafana-utils.local/docs/internal/schemas/grafana-utils-sync-preflight.schema.json",
  "title": "grafana-utils-sync-preflight",
  "type": "object",
  "required": [
    "kind",
    "schemaVersion",
    "traceId",
    "stage",
    "stepIndex",
    "parentTraceId",
    "summary",
    "checks"
  ],
  "properties": {
    "kind": {
      "const": "grafana-utils-sync-preflight"
    },
    "schemaVersion": {
      "const": 1
    },
    "traceId": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "const": "preflight"
    },
    "stepIndex": {
      "const": 2
    },
    "parentTraceId": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "required": [
        "resourceCount",
        "checkCount",
        "okCount",
        "blockingCount"
      ],
      "properties": {
        "resourceCount": {
          "type": "integer",
          "minimum": 0
        },
        "checkCount": {
          "type": "integer",
          "minimum": 0
        },
        "okCount": {
          "type": "integer",
          "minimum": 0
        },
        "blockingCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "identity",
          "status",
          "blocking",
          "detail"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "identity": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string"
          },
          "blocking": {
            "type": "boolean"
          },
          "detail": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
