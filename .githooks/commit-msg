#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:?missing commit message file}"

lines=()
while IFS= read -r line || [ -n "$line" ]; do
  lines+=("$line")
done < "$msg_file"

if [ "${#lines[@]}" -lt 3 ]; then
  echo "commit message must have a title, a blank line, and at least one detail bullet" >&2
  exit 1
fi

title="${lines[0]}"

if [[ ! "$title" =~ ^(feature|bugfix|refactor|docs|test|chore|build|ci|release):[[:space:]].+ ]]; then
  echo "commit title must start with a supported type prefix like 'refactor: short summary'" >&2
  exit 1
fi

if [ -n "${lines[1]}" ]; then
  echo "second line must be blank" >&2
  exit 1
fi

seen_bullet=0
for ((i = 2; i < ${#lines[@]}; i++)); do
  line="${lines[i]}"

  if [ -z "$line" ]; then
    if [ "$seen_bullet" -eq 1 ]; then
      echo "detail bullets must be contiguous with no empty lines between them" >&2
      exit 1
    fi
    continue
  fi

  if [[ ! "$line" =~ ^-\  ]]; then
    echo "detail lines must start with '- '" >&2
    exit 1
  fi

  seen_bullet=1
done

if [ "$seen_bullet" -ne 1 ]; then
  echo "commit message must include at least one detail bullet" >&2
  exit 1
fi
