#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:?missing commit message file}"
comment_char="$(git config --get core.commentChar 2>/dev/null || true)"

# Respect the repo's configured Git comment prefix so template/help lines
# from the editor do not count as commit content during validation.
if [ -z "$comment_char" ] || [ "$comment_char" = "auto" ]; then
  comment_char="#"
fi

lines=()
while IFS= read -r line || [ -n "$line" ]; do
  # Ignore Git-generated comment lines before enforcing the message shape.
  if [[ "$line" =~ ^[[:space:]]*"$comment_char" ]]; then
    continue
  fi
  lines+=("$line")
done < "$msg_file"

if [ "${#lines[@]}" -lt 3 ]; then
  echo "commit message must have a title, a blank line, and at least one detail bullet" >&2
  exit 1
fi

title="${lines[0]}"

# Enforce the repository's typed commit-title convention.
if [[ ! "$title" =~ ^(feature|bugfix|refactor|docs|test|chore|build|ci|release):[[:space:]].+ ]]; then
  echo "commit title must start with a supported type prefix like 'refactor: short summary'" >&2
  exit 1
fi

if [ -n "${lines[1]}" ]; then
  echo "second line must be blank" >&2
  exit 1
fi

seen_bullet=0
for ((i = 2; i < ${#lines[@]}; i++)); do
  line="${lines[i]}"

  # Allow leading empty lines before the first detail bullet, but once bullet
  # parsing starts the list must stay contiguous with no gaps.
  if [ -z "$line" ]; then
    if [ "$seen_bullet" -eq 1 ]; then
      echo "detail bullets must be contiguous with no empty lines between them" >&2
      exit 1
    fi
    continue
  fi

  if [[ ! "$line" =~ ^-\  ]]; then
    echo "detail lines must start with '- '" >&2
    exit 1
  fi

  seen_bullet=1
done

if [ "$seen_bullet" -ne 1 ]; then
  echo "commit message must include at least one detail bullet" >&2
  exit 1
fi
