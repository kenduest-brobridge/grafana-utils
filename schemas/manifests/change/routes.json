[
  {
    "routeId": "root.help",
    "title": "Workspace JSON schema guide",
    "intro": [
      "Use this help surface when CI, scripts, or external tooling need to understand which JSON document each `workspace` subcommand emits."
    ],
    "generalRule": [
      "Branch on `kind` plus `schemaVersion` before reading nested fields.",
      "`--output-format json` is the machine-readable path.",
      "`workspace package` writes a package contract through `--output-file`; it does not use `--output-format`."
    ],
    "contractSectionHeading": "Subcommand contracts",
    "contractSections": [
      { "contractId": "sync-summary", "label": "scan" },
      { "contractId": "sync-plan", "label": "preview" },
      { "contractId": "sync-plan-reviewed", "label": "ci mark-reviewed" },
      { "contractId": "sync-apply-intent", "label": "apply" },
      {
        "contractId": "sync-apply-live-result",
        "label": "apply --execute-live",
        "shapeLabel": "live apply result"
      },
      { "contractId": "sync-audit", "label": "audit" },
      { "contractId": "sync-preflight", "label": "test" },
      { "contractId": "alert-sync-plan", "label": "ci alert-readiness" },
      { "contractId": "sync-bundle-preflight", "label": "ci package-test" },
      { "contractId": "sync-promotion-preflight", "label": "ci promote-test" },
      { "contractId": "sync-source-bundle", "label": "package" }
    ],
    "quickLookups": [
      "grafana-util workspace --help-schema",
      "grafana-util workspace scan --help-schema",
      "grafana-util workspace test --help-schema",
      "grafana-util workspace preview --help-schema",
      "grafana-util workspace apply --help-schema"
    ]
  },
  {
    "routeId": "summary.help",
    "title": "Workspace scan JSON schema",
    "commands": [
      "grafana-util workspace scan --desired-file ./desired.json --fetch-live --profile prod --output-format json"
    ],
    "contractSections": [
      {
        "contractId": "sync-summary",
        "showNested": true
      }
    ]
  },
  {
    "routeId": "plan.help",
    "title": "Workspace preview JSON schema",
    "commands": [
      "grafana-util workspace preview --desired-file ./desired.json --fetch-live --profile prod --output-format json"
    ],
    "contractSections": [
      {
        "contractId": "sync-plan",
        "showNested": true
      }
    ]
  },
  {
    "routeId": "review.help",
    "title": "Workspace mark-reviewed JSON schema",
    "commands": [
      "grafana-util workspace ci mark-reviewed --plan-file ./sync-plan.json --output-format json"
    ],
    "contractSections": [
      {
        "contractId": "sync-plan-reviewed",
        "showNested": true
      }
    ],
    "notes": [
      "This is the reviewed sync-plan contract; new consumers should still route by `kind` plus `schemaVersion` before reading review metadata."
    ]
  },
  {
    "routeId": "apply.help",
    "title": "Workspace apply JSON schema",
    "commands": [
      "grafana-util workspace apply --plan-file ./sync-plan-reviewed.json --approve --output-format json",
      "grafana-util workspace apply --plan-file ./sync-plan-reviewed.json --approve --execute-live --profile prod --output-format json"
    ],
    "contractSectionHeading": "Contracts",
    "contractSections": [
      {
        "contractId": "sync-apply-intent",
        "label": "Default apply-intent kind",
        "showNested": true
      },
      {
        "contractId": "sync-apply-live-result",
        "label": "Live execute shape (`--execute-live`)",
        "shapeLabel": "live apply result",
        "showNested": true
      }
    ],
    "notes": [
      "The live apply result reports one entry per operation under `results[]`, with `kind`, `identity`, `action`, and `response`."
    ]
  },
  {
    "routeId": "audit.help",
    "title": "Workspace audit JSON schema",
    "commands": [
      "grafana-util workspace ci audit --lock-file ./sync-lock.json --fetch-live --profile prod --output-format json"
    ],
    "contractSections": [
      {
        "contractId": "sync-audit",
        "showNested": true
      }
    ]
  },
  {
    "routeId": "preflight.help",
    "title": "Workspace test JSON schema",
    "commands": [
      "grafana-util workspace test --desired-file ./desired.json --fetch-live --profile prod --output-format json"
    ],
    "contractSections": [
      {
        "contractId": "sync-preflight",
        "showNested": true
      }
    ]
  },
  {
    "routeId": "assess-alerts.help",
    "title": "Workspace alert-readiness JSON schema",
    "commands": [
      "grafana-util workspace ci alert-readiness --alerts-file ./alerts.json --output-format json"
    ],
    "contractSections": [
      {
        "contractId": "alert-sync-plan",
        "showNested": true
      }
    ]
  },
  {
    "routeId": "bundle-preflight.help",
    "title": "Workspace package-test JSON schema",
    "commands": [
      "grafana-util workspace ci package-test --source-bundle ./workspace-package.json --target-inventory ./target.json --output-format json"
    ],
    "contractSections": [
      {
        "contractId": "sync-bundle-preflight",
        "showNested": true
      }
    ]
  },
  {
    "routeId": "promotion-preflight.help",
    "title": "Workspace promote-test JSON schema",
    "commands": [
      "grafana-util workspace ci promote-test --source-bundle ./workspace-package.json --target-inventory ./target.json --mapping-file ./promotion-map.json --output-format json"
    ],
    "contractSections": [
      {
        "contractId": "sync-promotion-preflight",
        "showNested": true
      }
    ]
  },
  {
    "routeId": "bundle.help",
    "title": "Workspace package JSON contract",
    "commands": [
      "grafana-util workspace package --dashboard-export-dir ./dashboards/raw --alert-export-dir ./alerts/raw --output-file ./workspace-package.json"
    ],
    "contractSections": [
      {
        "contractId": "sync-source-bundle",
        "showNested": true
      }
    ],
    "notes": [
      "`workspace package` writes the contract to `--output-file`.",
      "It does not switch render modes with `--output-format`.",
      "Add `--also-stdout` only when you intentionally want both file output and stdout."
    ]
  }
]
