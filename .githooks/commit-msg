#!/usr/bin/env sh
set -eu

msg_file="$1"

# Allow merge/revert/fixup/squash commits without strict formatting.
first_line="$(sed -n '1p' "$msg_file")"
case "$first_line" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

if ! printf '%s\n' "$first_line" | grep -Eq '^(feature|bugfix|refactor|docs|test): .+'; then
  echo "commit-msg pre-check failed: first line must match '<type>: <subject>'." >&2
  echo "Allowed types: feature, bugfix, refactor, docs, test." >&2
  exit 1
fi

second_line="$(sed -n '2p' "$msg_file")"
if [ "${second_line}" != "" ]; then
  echo "commit-msg pre-check failed: line 2 must be blank." >&2
  exit 1
fi

details="$(sed -n '3,$p' "$msg_file")"
if [ -z "$details" ]; then
  echo "commit-msg pre-check failed: add one or more detail bullets after the blank line." >&2
  exit 1
fi

if printf '%s\n' "$details" | grep -Eq '^$'; then
  echo "commit-msg pre-check failed: do not put empty lines between detail bullets." >&2
  exit 1
fi

if ! printf '%s\n' "$details" | grep -Eq '^- .+'; then
  echo "commit-msg pre-check failed: detail lines must start with '- '." >&2
  exit 1
fi

if printf '%s\n' "$details" | grep -Evq '^- .+'; then
  echo "commit-msg pre-check failed: only '- ...' detail bullets are allowed after line 2." >&2
  exit 1
fi
