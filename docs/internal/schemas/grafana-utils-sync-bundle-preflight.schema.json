{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grafana-utils.local/docs/internal/schemas/grafana-utils-sync-bundle-preflight.schema.json",
  "title": "grafana-utils-sync-bundle-preflight",
  "type": "object",
  "required": [
    "kind",
    "schemaVersion",
    "traceId",
    "stage",
    "stepIndex",
    "parentTraceId",
    "summary",
    "syncPreflight",
    "providerAssessment"
  ],
  "properties": {
    "kind": {
      "const": "grafana-utils-sync-bundle-preflight"
    },
    "schemaVersion": {
      "const": 1
    },
    "traceId": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "const": "bundle-preflight"
    },
    "stepIndex": {
      "const": 2
    },
    "parentTraceId": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "required": [
        "resourceCount",
        "syncBlockingCount",
        "providerBlockingCount"
      ],
      "properties": {
        "resourceCount": {
          "type": "integer",
          "minimum": 0
        },
        "syncBlockingCount": {
          "type": "integer",
          "minimum": 0
        },
        "providerBlockingCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "syncPreflight": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "summary",
        "checks"
      ],
      "properties": {
        "kind": {
          "const": "grafana-utils-sync-preflight"
        },
        "schemaVersion": {
          "const": 1
        },
        "summary": {
          "type": "object"
        },
        "checks": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "providerAssessment": {
      "type": "object",
      "required": [
        "summary",
        "checks",
        "plans"
      ],
      "properties": {
        "summary": {
          "type": "object",
          "properties": {
            "blockingCount": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": true
        },
        "checks": {
          "type": "array"
        },
        "plans": {
          "type": "array"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
